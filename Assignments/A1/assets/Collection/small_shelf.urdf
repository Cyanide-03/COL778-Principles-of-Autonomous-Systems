    <!-- Inertial properties for the whole stand -->
    <inertial>
      <origin xyz="0 0 0.20" rpy="0 0 0"/>
      <mass value="5.0"/> <!-- total mass in kg -->
      <inertia ixx="0.2" iyy="0.2" izz="0.2" ixy="0" ixz="0" iyz="0"/>
    </inertial>

  </link>

</robot>
